{
  "title": "SymptoBridge AI — Service Overview",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency by route (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 4,
      "title": "Real-user LCP p75 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.75, sum(rate(web_vitals_value_bucket{metric=\"LCP\"}[1h])) by (le))",
          "legendFormat": "LCP p75"
        }
      ]
    },
    {
      "id": 5,
      "title": "Real-user CLS p75",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.75, sum(rate(web_vitals_value_bucket{metric=\"CLS\"}[1h])) by (le))",
          "legendFormat": "CLS p75"
        }
      ]
    },
    {
      "id": 6,
      "title": "Process memory (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }
      ]
    },
    {
      "id": 7,
      "title": "Event loop lag p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "nodejs_eventloop_lag_p95_seconds", "legendFormat": "lag p95" }
      ]
    }
  ]
}
